:80 {
    reverse_proxy frontend:3000

    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    encode zstd gzip

    log {
        output file /var/log/caddy/access.log
        format json
    }
}
